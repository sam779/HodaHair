{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "env": {
    "GOOGLE_CLIENT_ID": "@google_client_id",
    "GOOGLE_CLIENT_SECRET": "@google_client_secret",
    "GOOGLE_REDIRECT_URI": "@google_redirect_uri",
    "TIMEZONE": "@timezone"
  },
  "redirects": [
    {
      "source": "/auth/callback",
      "destination": "/api/auth",
      "permanent": false
    }
  ]
}
