# Google OAuth Credentials
# Get these from Google Cloud Console

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Admin setup redirect URI (customer one-time authorization)
GOOGLE_ADMIN_REDIRECT_URI=http://localhost:3000/api/admin/auth
# For production: GOOGLE_ADMIN_REDIRECT_URI=https://your-domain.com/api/admin/auth

# Timezone for calendar events (adjust to customer's timezone)
TIMEZONE=America/New_York
